<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D3E5FF"
    android:padding="16dp">

    <TextView
        android:id="@+id/samuelTitleTV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Portrait Samuel Pecora n01437931"
        android:textColor="#FF0000"
        android:textStyle="bold"
        android:textSize="24sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp" />

    <EditText
        android:id="@+id/samuelInputET"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter 6 digits"
        android:inputType="number"
        android:maxLength="6"
        app:layout_constraintTop_toBottomOf="@id/samuelTitleTV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp" />

    <ImageButton
        android:id="@+id/samuelSubmitBtn"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/ic_media_play"
        android:contentDescription="Submit Button"
        app:layout_constraintTop_toBottomOf="@id/samuelInputET"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp" />

</androidx.constraintlayout.widget.ConstraintLayout>